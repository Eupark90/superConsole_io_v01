{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "Debug"
            ],
            "group": "build",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Upload Debug",
            "type": "shell",
            "command": "${userHome}/.local/share/stm32cube/bundles/programmer/2.22.0+st.1/bin/STM32_Programmer_CLI",
            "args": [
                "-c",
                "port=SWD",
                "mode=UR",
                "-w",
                "${workspaceFolder}/build/Debug/superConsoleV01_IO.elf",
                "-v",
                "-rst"
            ],
            "dependsOn": "Build Debug",
            "problemMatcher": []
        }
    ]
}
